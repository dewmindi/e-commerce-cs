// ─────────────────────────────────────────────────────────────────────────────
// Shared Prisma schema — used by BOTH e-commerce-cs and Admin-Panel-CS
// Both projects point DATABASE_URL / DIRECT_URL to the same Supabase project.
// Run migrations only from Admin-Panel-CS (source of truth).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled URL  → used by Next.js serverless functions (PgBouncer)
  url       = env("DATABASE_URL")
  // Direct URL  → used by `prisma migrate` and `prisma db push`
  directUrl = env("DIRECT_URL")
}

// ─── Service Catalog ─────────────────────────────────────────────────────────

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  description   String?
  order         Int           @default(0)
  subcategories Subcategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("categories")
}

model Subcategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  order       Int       @default(0)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  packages    Package[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
  @@map("subcategories")
}

model Package {
  id            String      @id @default(cuid())
  name          String
  price         Decimal     @db.Decimal(10, 2)
  overview      String?
  /// JSON: Array<{ name: string; value: boolean } | { title: string; items: { text: string; highlight: boolean }[] }>
  features      Json?
  active        Boolean     @default(true)
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([subcategoryId])
  @@map("packages")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

/// Stripe checkout orders — created automatically via webhook (e-commerce-cs)
model StripeOrder {
  id                    String   @id @default(cuid())
  orderId               String   @unique
  stripeSessionId       String?  @unique
  stripePaymentIntentId String   @unique
  customerName          String?
  email                 String?
  phone                 String?
  projectNote           String?
  /// JSON: Array<{ id: string; name: string; price: number; quantity: number }>
  items                 Json     @default("[]")
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("aud")
  /// paid | failed | expired | canceled
  status                String   @default("paid")
  failureReason         String?
  /// Pending | Started | Completed | canceled
  fulfillmentStatus     String   @default("Pending")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([stripePaymentIntentId])
  @@index([email])
  @@map("stripe_orders")
}

/// CRM service orders — manually managed in Admin-Panel-CS
model ServiceOrder {
  id                String    @id @default(cuid())
  customerName      String
  customerEmail     String
  /// web-design | graphic-design | seo | branding | social-media | other
  service           String
  description       String
  amount            Decimal   @db.Decimal(10, 2)
  /// pending | in-progress | completed | cancelled
  fulfillmentStatus String    @default("pending")
  dueDate           DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerEmail])
  @@map("service_orders")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

/// Unified blog posts table — covers both the e-commerce simple blog
/// and the Admin auto-blog pipeline with full SEO / featured-image fields.
model BlogPost {
  id      String  @id @default(cuid())
  title   String
  slug    String  @unique
  /// Full HTML / Markdown content
  content String  @db.Text
  excerpt String?

  // SEO
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String[] // PostgreSQL native array
  /// Legacy single keyword field (e-commerce simple blog)
  keyword         String?  @unique
  /// Legacy metaDescription field
  metaDescription String?

  // Source tracking (auto-blog pipeline)
  sourceUrl  String?
  /// MD5 of sourceUrl — dedup guard (sparse, allows NULL)
  sourceHash String?  @unique

  // ── Featured image — all stored in Supabase Storage "blog-image" bucket ──
  /// Primary public URL (original or WebP — used by frontend <img src>)
  featuredImageUrl    String?
  /// Storage path for deletion  e.g. "featured/my-post-title.webp"
  featuredImagePath   String?
  /// WebP variant public URL    (served to modern browsers)
  featuredImageWebp   String?
  /// WebP storage path for deletion
  featuredImageWebpPath String?
  /// AVIF variant public URL    (best compression — Chrome/Firefox/Safari 16+)
  featuredImageAvif   String?
  /// AVIF storage path for deletion
  featuredImageAvifPath String?
  /// Intrinsic width  — set in HTML width attr to prevent CLS
  featuredImageWidth  Int?
  /// Intrinsic height — set in HTML height attr to prevent CLS
  featuredImageHeight Int?

  /// published | draft
  status    String   @default("published")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("blog_posts")
}

// ─── Reviews ────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  name      String
  rating    Int      @default(5)
  comment   String
  service   String?
  avatarUrl String?
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

// ─── Portfolio ───────────────────────────────────────────────────────────────

model PortfolioItem {
  id          String   @id @default(cuid())
  service     String
  title       String
  weblink     String?
  description String?
  /// Supabase Storage public URL
  imageUrl    String
  /// Storage bucket path used for deletion (e.g. "portfolio/xyz.jpg")
  storagePath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([service])
  @@map("portfolio_items")
}

// ─── Hosting ─────────────────────────────────────────────────────────────────

model HostingPlan {
  id                   String            @id @default(cuid())
  name                 String
  description          String
  monthlyPrice         Decimal           @db.Decimal(10, 2)
  yearlyPrice          Decimal           @db.Decimal(10, 2)
  features             String[]
  stripeProductId      String?
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  customers            HostingCustomer[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@map("hosting_plans")
}

model HostingCustomer {
  id                   String      @id @default(cuid())
  customerName         String
  customerEmail        String
  domain               String
  /// active | suspended | expired | cancelled
  status               String      @default("active")
  startDate            DateTime
  renewalDate          DateTime
  amount               Decimal     @db.Decimal(10, 2)
  /// monthly | yearly
  billingCycle         String      @default("yearly")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  notes                String?
  planId               String
  plan                 HostingPlan @relation(fields: [planId], references: [id])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([stripeCustomerId])
  @@index([renewalDate])
  @@map("hosting_customers")
}

// ─── CMS Content Pages ───────────────────────────────────────────────────────

model ContentPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  /// JSON: Section[] — hero | text | image | gallery | cta | features | testimonials
  sections        Json     @default("[]")
  /// draft | published
  status          String   @default("draft")
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("content_pages")
}

// ─── Admin Auth ──────────────────────────────────────────────────────────────

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model AdminSession {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  rememberMe Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([email])
  @@map("admin_sessions")
}

model AdminOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([email])
  @@map("admin_otps")
}

// ─── Services Catalog (redesigned packages system) ───────────────────────────

model Service {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  description String?
  icon        String?
  active      Boolean      @default(true)
  subServices SubService[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("services")
}

model SubService {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  description String?
  active      Boolean          @default(true)
  serviceId   String
  service     Service          @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  packages    ServicePackage[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([serviceId])
  @@map("sub_services")
}

model ServicePackage {
  id           String     @id @default(cuid())
  name         String
  price        Decimal    @db.Decimal(10, 2)
  description  String?
  /// JSON: Array<{ text: string; included: boolean }>
  features     Json?
  /// JSON: { deliverables: string[]; timeline: { week: string; tasks: string }[]; exclusions: string[] }
  quotationFeatures Json?
  popular      Boolean    @default(false)
  active       Boolean    @default(true)
  subServiceId String
  subService   SubService @relation(fields: [subServiceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([subServiceId])
  @@map("service_packages")
}

// ─── Multi-Tenant Blog Service ────────────────────────────────────────────────
// Provides automated SEO blog generation as a service for external client sites.
// Each ManagedSite is a client website; ManagedBlogPost stores every generated blog.

/// A client website enrolled in the automated SEO blog service.
model ManagedSite {
  id          String @id @default(cuid())
  /// Human-readable client/site name (e.g. "Visit Kataragama")
  name        String
  /// Primary domain without trailing slash (e.g. "https://www.visitkataragama.com")
  domain      String @unique
  /// Short niche description — fed to the AI to generate relevant topics
  /// e.g. "Sri Lanka tourism, Kataragama temple, Yala safari, wildlife"
  niche       String
  /// Country/region for Google Trends geo filter (e.g. "LK", "AU", "US")
  geoTarget   String @default("US")
  /// Timezone name for scheduling display (e.g. "Asia/Colombo")
  timezone    String @default("UTC")

  // ── Publish target ────────────────────────────────────────────────────────
  /// Full URL of the site's blog-ingest API endpoint
  /// e.g. "https://www.visitkataragama.com/api/blogs/auto-create"
  /// Leave blank to store-only (no push delivery)
  publishEndpoint String?
  /// Bearer token / webhook secret sent in Authorization header to publishEndpoint
  publishSecret   String?

  // ── GSC / competitor keyword injection ───────────────────────────────────
  /// JSON: string[] — top-clicked GSC keywords updated monthly by the admin
  gscKeywords      Json @default("[]")
  /// JSON: string[] — competitor SEO keywords to outrank
  competitorKeywords Json @default("[]")
  /// JSON: string[] — curated blog scenario objects { id, topic, angle }
  scenarios        Json @default("[]")

  // ── Schedule ─────────────────────────────────────────────────────────────
  /// Blogs per day (1–5)
  postsPerDay Int     @default(3)
  /// active | paused
  status      String  @default("active")

  blogPosts   ManagedBlogPost[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@map("managed_sites")
}

/// A single AI-generated blog post for a ManagedSite.
model ManagedBlogPost {
  id      String @id @default(cuid())
  siteId  String
  site    ManagedSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  title   String
  slug    String
  /// Full HTML content
  content String  @db.Text
  excerpt String?

  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]

  // Image — stored in Supabase Storage "managed-blog-images" bucket
  imageUrl   String?
  imagePath  String?

  // Publishing status
  /// draft | published | failed
  status      String  @default("published")
  /// Whether successfully delivered to the target site's API
  delivered   Boolean @default(false)
  /// HTTP status returned by publishEndpoint (null = store-only)
  deliveryStatus Int?
  /// Revalidation attempted
  revalidated Boolean @default(false)

  // Source / dedup
  scenarioId  String?
  sourceHash  String?

  category    String?
  /// JSON: string[]
  tags        Json @default("[]")

  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([siteId, publishedAt(sort: Desc)])
  @@map("managed_blog_posts")
}
