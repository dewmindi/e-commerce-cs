// ─────────────────────────────────────────────────────────────────────────────
// Shared Prisma schema — used by BOTH e-commerce-cs and Admin-Panel-CS
// Both projects point DATABASE_URL / DIRECT_URL to the same Supabase project.
// Run migrations only from Admin-Panel-CS (source of truth).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled URL  → used by Next.js serverless functions (PgBouncer)
  url       = env("DATABASE_URL")
  // Direct URL  → used by `prisma migrate` and `prisma db push`
  directUrl = env("DIRECT_URL")
}

// ─── Service Catalog ─────────────────────────────────────────────────────────

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  description   String?
  order         Int           @default(0)
  subcategories Subcategory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("categories")
}

model Subcategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  order       Int       @default(0)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  packages    Package[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([categoryId])
  @@map("subcategories")
}

model Package {
  id            String      @id @default(cuid())
  name          String
  price         Decimal     @db.Decimal(10, 2)
  overview      String?
  /// JSON: Array<{ name: string; value: boolean } | { title: string; items: { text: string; highlight: boolean }[] }>
  features      Json?
  active        Boolean     @default(true)
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([subcategoryId])
  @@map("packages")
}

// ─── Orders ──────────────────────────────────────────────────────────────────

/// Stripe checkout orders — created automatically via webhook (e-commerce-cs)
model StripeOrder {
  id                    String   @id @default(cuid())
  orderId               String   @unique
  stripeSessionId       String?  @unique
  stripePaymentIntentId String   @unique
  customerName          String?
  email                 String?
  phone                 String?
  projectNote           String?
  /// JSON: Array<{ id: string; name: string; price: number; quantity: number }>
  items                 Json     @default("[]")
  amount                Decimal  @db.Decimal(10, 2)
  currency              String   @default("aud")
  /// paid | failed | expired | canceled
  status                String   @default("paid")
  failureReason         String?
  /// Pending | Started | Completed | canceled
  fulfillmentStatus     String   @default("Pending")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([stripePaymentIntentId])
  @@index([email])
  @@map("stripe_orders")
}

/// CRM service orders — manually managed in Admin-Panel-CS
model ServiceOrder {
  id                String    @id @default(cuid())
  customerName      String
  customerEmail     String
  /// web-design | graphic-design | seo | branding | social-media | other
  service           String
  description       String
  amount            Decimal   @db.Decimal(10, 2)
  /// pending | in-progress | completed | cancelled
  fulfillmentStatus String    @default("pending")
  dueDate           DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerEmail])
  @@map("service_orders")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

/// Unified blog posts table — covers both the e-commerce simple blog
/// and the Admin auto-blog pipeline with full SEO / featured-image fields.
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  /// Full HTML / Markdown content
  content     String   @db.Text
  excerpt     String?

  // SEO
  seoTitle        String?
  seoDescription  String?
  seoKeywords     String[] // PostgreSQL native array
  /// Legacy single keyword field (e-commerce simple blog)
  keyword         String?  @unique
  /// Legacy metaDescription field
  metaDescription String?

  // Source tracking (auto-blog pipeline)
  sourceUrl  String?
  /// MD5 of sourceUrl — dedup guard (sparse, allows NULL)
  sourceHash String?  @unique

  // Featured image — stored in Supabase Storage bucket "blog-images"
  featuredImageUrl    String?
  featuredImageFileId String?
  featuredImageWidth  Int?
  featuredImageHeight Int?

  /// published | draft
  status    String   @default("published")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("blog_posts")
}

// ─── Reviews ────────────────────────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  name       String
  rating     Int      @default(5)
  comment    String
  service    String?
  avatarUrl  String?
  approved   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("reviews")
}

// ─── Portfolio ───────────────────────────────────────────────────────────────

model PortfolioItem {
  id          String   @id @default(cuid())
  service     String
  title       String
  weblink     String?
  description String?
  /// Supabase Storage public URL
  imageUrl    String
  /// Storage bucket path used for deletion (e.g. "portfolio/xyz.jpg")
  storagePath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([service])
  @@map("portfolio_items")
}

// ─── Hosting ─────────────────────────────────────────────────────────────────

model HostingPlan {
  id                   String            @id @default(cuid())
  name                 String
  description          String
  monthlyPrice         Decimal           @db.Decimal(10, 2)
  yearlyPrice          Decimal           @db.Decimal(10, 2)
  features             String[]
  stripeProductId      String?
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  customers            HostingCustomer[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@map("hosting_plans")
}

model HostingCustomer {
  id                   String      @id @default(cuid())
  customerName         String
  customerEmail        String
  domain               String
  /// active | suspended | expired | cancelled
  status               String      @default("active")
  startDate            DateTime
  renewalDate          DateTime
  amount               Decimal     @db.Decimal(10, 2)
  /// monthly | yearly
  billingCycle         String      @default("yearly")
  stripeCustomerId     String?
  stripeSubscriptionId String?
  notes                String?
  planId               String
  plan                 HostingPlan @relation(fields: [planId], references: [id])
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@index([stripeCustomerId])
  @@index([renewalDate])
  @@map("hosting_customers")
}

// ─── CMS Content Pages ───────────────────────────────────────────────────────

model ContentPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  /// JSON: Section[] — hero | text | image | gallery | cta | features | testimonials
  sections        Json     @default("[]")
  /// draft | published
  status          String   @default("draft")
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("content_pages")
}

// ─── Admin Auth ──────────────────────────────────────────────────────────────

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}

model AdminSession {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  rememberMe Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([email])
  @@map("admin_sessions")
}

model AdminOtp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([email])
  @@map("admin_otps")
}
